# ============================================
# 中东局势情报追踪器 - Git 忽略文件
# ============================================

# ── 环境变量和敏感信息 ───────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Python ──────────────────────────────────
# 字节码
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
ENV/
.venv/

# 分发/打包
build/
dist/
*.egg-info/
.eggs/

# 测试
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ── Node.js / 前端 ──────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 构建输出
dist/
dist-ssr/
*.local

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── 数据库 ──────────────────────────────────
# SQLite 数据库文件（数据通过备份管理，不提交到git）
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# 但保留 data 目录结构（通过 .gitkeep）
!data/.gitkeep

# ── 日志文件 ────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# ── 操作系统 ────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*

# ── Docker ──────────────────────────────────
.dockerignore

# ── 备份文件 ────────────────────────────────
*.bak
*.backup
*.swp
*.tmp
*.temp

# ── 上传文件（如用户上传的头像等）────────────
uploads/
media/

# ── 本地开发配置 ────────────────────────────
.vscode/settings.json
.idea/
*.iml

# ── 其他 ────────────────────────────────────
.cache/
.temp/
.tmp/
