# 复制此文件为 .env 并填入你的 API Key

# ============================================
# 大模型配置 (LLM Configuration)
# ============================================

# API Key
# 阿里云百炼平台: https://bailian.console.aliyun.com/
# OpenAI: https://platform.openai.com/api-keys
LLM_API_KEY=your_api_key_here

# 模型名称
# dashscope 可选: qwen-turbo, qwen-plus, qwen-max
# openai 可选: gpt-3.5-turbo, gpt-4, gpt-4-turbo
LLM_MODEL=qwen-plus

# API Base URL (可选，用于自定义端点)
# 阿里云默认: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI 默认: https://api.openai.com/v1
# 如需修改默认地址，请取消注释并填写
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

